{
  "name": "free-calling-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "cap:sync": "npx cap sync",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "mobile:prepare": "npm run build && npm run cap:sync",
    "electron:dev": "wait-on tcp:5173 && electron electron/main.cjs",
    "desktop:dev": "concurrently -k \"npm run dev\" \"npm run electron:dev\"",
    "desktop:build": "npm run build && node ./scripts/desktop-build.mjs dir",
    "desktop:dist": "npm run build && node ./scripts/desktop-build.mjs dist"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.freecalling.desktop",
    "productName": "Free Calling App",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    }
  }
}
